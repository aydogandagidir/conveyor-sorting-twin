# Copy to deployment/.env and adjust. Used by docker-compose.yml.

# Soft-PLC Modbus TCP slave
MODBUS_PORT=15502
OLTWIN_REGISTRY=conveyor_sorting_cell   # or sorting_cell_mvp
OLTWIN_CONTROL=control_logic            # or control_logic_mvp / control_logic_advanced

# FUXA HMI (full/hmi profile)
FUXA_PORT=1881

# Node-RED (integration profile)
NODERED_PORT=1880

# Local (non-docker) telemetry export location used by the scripts
EXPORT_DIR=telemetry/exports
