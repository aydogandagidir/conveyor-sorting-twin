; OpenLogiTwin — Godot 4.x project (minimal scaffold).
;
; Build the sorting-cell scene in the Godot editor following docs/GODOT_SCENE.md
; (Conveyor, PE_001@20cm, PE_002@80cm, Diverter@90cm, ChuteA/ChuteB, Parcel).
; modbus_client.gd / cell_bridge.gd connect to the soft-PLC (scripts/run_soft_plc.py)
; over Modbus TCP and drive the scene from the same tag contract as scene_model.py.
;
; STATUS: cell.tscn + cell.gd author the scene; verified to import and run on Godot 4.2
; headless (2026-06-20). Open in the Godot editor for visual play/polish.

config_version=5

[application]

config/name="OpenLogiTwin Sorting Cell"
config/features=PackedStringArray("4.2")
run/main_scene="res://cell.tscn"

[autoload]

CellBridge="*res://cell_bridge.gd"
